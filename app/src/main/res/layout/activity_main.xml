<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0A2E">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JÖRMUNGANDR"
        android:textSize="42sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp" />

    <TextView
        android:id="@+id/subtitle_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A Roguelike Adventure"
        android:textSize="16sp"
        android:textColor="#AAAAAA"
        android:fontFamily="serif"
        app:layout_constraintTop_toBottomOf="@id/title_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btn_new_game"
        android:layout_width="250dp"
        android:layout_height="56dp"
        android:text="New Game"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4B0082"
        app:layout_constraintTop_toBottomOf="@id/subtitle_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp" />

    <Button
        android:id="@+id/btn_continue"
        android:layout_width="250dp"
        android:layout_height="56dp"
        android:text="Continue"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E1A47"
        app:layout_constraintTop_toBottomOf="@id/btn_new_game"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:id="@+id/new_game_panel"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp"
        android:background="@drawable/panel_background"
        app:layout_constraintTop_toBottomOf="@id/subtitle_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Access Code"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/access_code_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Enter access code"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:inputType="text"
            android:maxLength="20" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Character Name"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/player_name_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Enter name"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:inputType="textPersonName"
            android:maxLength="20" />

        <Button
            android:id="@+id/btn_start_game"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Start Adventure"
            android:textColor="#FFFFFF"
            android:backgroundTint="#228B22"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/version_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="12sp"
        android:textColor="#555555"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
