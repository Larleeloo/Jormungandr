<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.larleeloo.jormungandr.view.RoomCanvasView
        android:id="@+id/room_canvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay for interaction messages -->
    <TextView
        android:id="@+id/room_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="#AA000000"
        android:visibility="gone" />

    <!-- Portal Doors button (shown in waypoint/hub rooms) -->
    <Button
        android:id="@+id/btn_portal_doors"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:text="Portal Doors"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4B0082"
        android:minWidth="0dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:visibility="gone" />

    <!-- Use Torch button -->
    <Button
        android:id="@+id/btn_use_torch"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="12dp"
        android:text="Use Torch"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF8C00"
        android:minWidth="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone" />

    <!-- Leave Note button -->
    <Button
        android:id="@+id/btn_leave_note"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:text="Leave Note"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4B0082"
        android:minWidth="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

</FrameLayout>
